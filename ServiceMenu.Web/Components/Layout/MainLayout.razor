@using ServiceMenu.Web.Components.Shared
@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-egg-fried me-2"></i>
                    Good Hamburger
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" 
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                                <i class="bi bi-shop me-1"></i>Cardápio
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/pedidos">
                                <i class="bi bi-list-ul me-1"></i>Pedidos
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/carrinho">
                                <i class="bi bi-cart3 me-1"></i>Carrinho
                                <CarrinhoBadge />
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container my-4">
        @Body
    </main>

    <footer class="footer mt-auto py-3 bg-light">
        <div class="container text-Left">
            <span class="text-muted">© By Matheus Solon Craveiro</span>
        </div>
    </footer>
</div>